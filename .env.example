# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=psycheforum
DB_USER=your_username
DB_PASSWORD=

# JWT Secrets (change these to random strings in production)
JWT_SECRET=psyche-forum-super-secret-jwt-change-in-prod
JWT_REFRESH_SECRET=psyche-refresh-secret-change-this-too
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Server
PORT=3000
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Admin
ADMIN_SETUP_KEY=psyche-admin-setup-2026

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=5242880
